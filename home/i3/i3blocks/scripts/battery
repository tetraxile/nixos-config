#!/bin/sh

BAT=$(acpi -b | grep -E -o '[0-9][0-9]?[0-9]?%')

if acpi -b | grep -q "Charging"; then
	echo "<span size=\"large\">鷄サ鷄ォ</span> $BAT"
	exit 0
elif [ ${BAT%?} -le 40 ]; then
	icon="鷄サ鷄え"
else
	icon="鷄サ鷄ィ"
fi

echo "<span size=\"large\">$icon</span> $BAT"

[[ ${BAT%?} -le 15 ]] && exit 33 || exit 0
